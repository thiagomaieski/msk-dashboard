VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# ── Pré-Qualificação de Leads ──────────────────────────────────────────────

# 1. Google PageSpeed Insights API — Performance Mobile/Desktop
#    Cadastro: https://console.developers.google.com/ (habilite PageSpeed Insights API)
VITE_PAGESPEED_API_KEY=

# 2. Screenshot API — Print full-page do site
#    Sugerido: ScreenshotMachine (https://www.screenshotmachine.com/api.php)
#    Adapte o endpoint em src/utils/prequalApi.js se usar outro serviço
VITE_SCREENSHOT_API_KEY=

# 3. Apify API — Dados do Instagram (seguidores, bio, último post)
#    Cadastro: https://console.apify.com/account/integrations
#    Actor usado: apify/instagram-profile-scraper
VITE_APIFY_API_KEY=
